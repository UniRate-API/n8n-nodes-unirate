{
	"name": "n8n-nodes-unirate",
	"version": "0.1.2",
	"description": "n8n community node for the UniRate API — currency conversion, exchange rates, historical rates, time series, and VAT rates.",
	"keywords": [
		"n8n-community-node-package",
		"unirate",
		"exchange-rates",
		"currency",
		"forex",
		"vat",
		"fintech",
		"fx"
	],
	"license": "MIT",
	"homepage": "https://github.com/UniRate-API/n8n-nodes-unirate",
	"author": {
		"name": "Unirate Team",
		"email": "admin@unirateapi.com",
		"url": "https://unirateapi.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/UniRate-API/n8n-nodes-unirate.git"
	},
	"engines": {
		"node": ">=20.15"
	},
	"main": "index.js",
	"scripts": {
		"build": "tsc && node copy-assets.js",
		"dev": "tsc --watch",
		"format": "prettier nodes credentials --write",
		"lint": "eslint nodes credentials package.json",
		"lintfix": "eslint nodes credentials package.json --fix",
		"prepublishOnly": "npm run build && npm run lint -s"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/UniRateApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/UniRate/UniRate.node.js",
			"dist/nodes/UniRateTrigger/UniRateTrigger.node.js"
		]
	},
	"devDependencies": {
		"@typescript-eslint/parser": "^8.32.0",
		"eslint": "^8.57.0",
		"eslint-plugin-n8n-nodes-base": "^1.16.3",
		"n8n-workflow": "*",
		"prettier": "^3.3.3",
		"typescript": "^5.6.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
